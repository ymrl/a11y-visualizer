---
import "../styles/global.css";

export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ariaNotify in iFrame</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto",
          "Oxygen", sans-serif;
        padding: 24px;
        margin: 0;
        background: linear-gradient(135deg, #e9d5ff 0%, #f5f3ff 100%);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
      }
      .container {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        max-width: 400px;
        text-align: center;
      }
      h1 {
        color: #6b21a8;
        margin: 0 0 16px 0;
        font-size: 1.5rem;
        font-weight: 700;
      }
      p {
        color: #374151;
        line-height: 1.6;
        margin: 0 0 16px 0;
      }
      button {
        background: linear-gradient(135deg, #9333ea, #7c3aed);
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(147, 51, 234, 0.3);
      }
      button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(147, 51, 234, 0.4);
      }
      button:active {
        transform: translateY(0);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>ariaNotify in iFrame</h1>
      <p>Click the button to call document.ariaNotify() inside this iframe.</p>
      <button id="notify-btn">Call ariaNotify</button>
    </div>
    <script>
      (function () {
        let count = 0;
        document
          .getElementById("notify-btn")
          .addEventListener("click", function () {
            count++;
            if (document.ariaNotify) {
              document.ariaNotify(
                "Notification #" +
                  count +
                  " from iframe at " +
                  new Date().toLocaleTimeString(),
              );
            }
          });
      })();
    </script>
  </body>
</html>
